# ==============================================================================
#  PORTFOLIO TEMPLATE - ENVIRONMENT VARIABLES (SECRETS & DEPLOYMENT ONLY)
# ==============================================================================
#  Setup:
#  1. Copy this file to .env.local:  cp .env.example .env.local
#  2. Fill in your values in .env.local
#  3. Never commit .env.local to version control.
#
#  NOTE: All PERSONALIZATION (name, headline, email, phone, address, socials,
#  serverUrl, SEO descriptions, legal hosting/analytics text) lives in
#  site.config.json — NOT in env vars. Edit it in your private "portfolio-config"
#  repo (auto-detected via the "portfolio-config" topic), or locally in
#  config/site.config.json. See config/site.config.example.json for the schema.
# ==============================================================================

# ------------------------------------------------------------------------------
#  GITHUB INTEGRATION  (build-time only)
# ------------------------------------------------------------------------------
# A GitHub Personal Access Token with `repo` scope. Used at build time by
# scripts/fetch-portfolio.ts to: list your repos, read each project's optional
# .portfolio/ folder, and pull your portfolio-config repo (site.config.json,
# resume.json, profile image, resume.pdf). Without it the script falls back to
# the public GitHub API (public repos only, 60 req/hr).
# Generate one at: https://github.com/settings/tokens
GITHUB_TOKEN="ghp_yourtokenhere"

# (Optional) Explicit GitHub username. Normally derived automatically from the
# token (/user). Only needed when running without a token (public fallback).
# GITHUB_USER=""

# (Optional) Force a specific config repository name. By default the build
# auto-detects the repo tagged with the "portfolio-config" topic. That repo
# should contain a .portfolio/ folder with:
#     .portfolio/site.config.json   (personalization — see example schema)
#     .portfolio/resume.json        (CV data for the /resume page)
#     .portfolio/profile.png        (avatar; .jpg/.webp also accepted)
#     .portfolio/resume.pdf         (downloadable CV — optional)
# PORTFOLIO_CONFIG_REPO=""

# (Optional) Force the bundled demo / template dataset (the committed demo/ tree:
# 6 mock projects, a generic site.config.json, resume and profile image) instead
# of real GitHub data. Useful for previewing the template or publishing a public
# live demo with no secrets. Demo mode is also entered automatically on a clean
# clone (no token and no repositories discovered). Set to 1 to force it.
# PORTFOLIO_DEMO=1

# ------------------------------------------------------------------------------
#  EMAIL / CONTACT FORM  (runtime — required for the contact form to work)
# ------------------------------------------------------------------------------
SMTP_HOST="smtp.example.com"
SMTP_PORT=465
SMTP_USER="apikey"
SMTP_PASS="your-smtp-password"
# (Optional) From: address for outgoing mail. Falls back to site.config.json
# contact.smtpFrom, then SMTP_USER.
# SMTP_FROM="server@example.com"

# ------------------------------------------------------------------------------
#  ANALYTICS  (Umami — self-hosted, privacy-friendly, no cookies; optional)
# ------------------------------------------------------------------------------
# Internal URL of your Umami instance reachable from the app container.
# In production (Docker): http://host.docker.internal:3001
# In local dev: http://localhost:3001  (if Umami is running locally)
# Leave empty to disable analytics entirely.
UMAMI_INTERNAL_URL=""
# The website ID shown in Umami → Settings → Websites
UMAMI_WEBSITE_ID=""
