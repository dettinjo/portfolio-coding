# ==============================================================================
#  PORTFOLIO TEMPLATE - ENVIRONMENT VARIABLES
# ==============================================================================
#  Setup:
#  1. Copy this file to .env.local:  cp .env.example .env.local
#  2. Fill in your values in .env.local
#  3. Never commit .env.local to version control.
# ==============================================================================

# ------------------------------------------------------------------------------
#  APPLICATION SETTINGS
# ------------------------------------------------------------------------------
# The public URL of your portfolio site (e.g., https://yourdomain.com)
NEXT_PUBLIC_SERVER_URL="http://localhost:3000"

# ------------------------------------------------------------------------------
#  GITHUB INTEGRATION
# ------------------------------------------------------------------------------
# Your GitHub username — used to fetch repositories and build the project list.
NEXT_PUBLIC_GITHUB_USERNAME="johndoe"

# A GitHub Personal Access Token with `read:user` and `public_repo` scopes.
# Required for higher API rate limits and to access private/organisation repos.
# Generate one at: https://github.com/settings/tokens
GITHUB_TOKEN="ghp_yourtokenhere"

# (Optional) Override for the config repository name.
# By default the build script auto-detects it by looking for a repo tagged
# with the "portfolio-config" topic — no value needed if that topic is set.
# Only set this if you want to force a specific repo name instead.
#   Expected structure: .portfolio/resume.json
#                       .portfolio/profile.jpg  (or .png / .webp)
#                       .portfolio/resume.pdf
# Leave empty to use auto-detection or fall back to the local config/ folder.
PORTFOLIO_CONFIG_REPO=""

# ------------------------------------------------------------------------------
#  PERSONAL INFORMATION  (shown in hero, contact, imprint, SEO meta)
# ------------------------------------------------------------------------------
NEXT_PUBLIC_FULL_NAME="John Doe"
NEXT_PUBLIC_EMAIL_ADDRESS="john.doe@example.com"
NEXT_PUBLIC_PHONE_NUMBER="+1 555 0123 456"
NEXT_PUBLIC_STREET_ADDRESS="123 Tech Avenue"
NEXT_PUBLIC_CITY_ADDRESS="San Francisco, CA 94107"

# ------------------------------------------------------------------------------
#  SOCIAL PROFILES  (usernames only — URLs are generated automatically)
# ------------------------------------------------------------------------------
NEXT_PUBLIC_GITHUB_USERNAME="johndoe"
NEXT_PUBLIC_LINKEDIN_USERNAME="johndoe"
NEXT_PUBLIC_INSTAGRAM_USERNAME="johndoe_grams"

# ------------------------------------------------------------------------------
#  EMAIL / CONTACT FORM  (SMTP for the contact form submission)
# ------------------------------------------------------------------------------
SMTP_HOST="smtp.example.com"
SMTP_PORT=465
SMTP_USER="apikey"
SMTP_PASS="your-smtp-password"

# ------------------------------------------------------------------------------
#  ANALYTICS  (Umami — self-hosted, privacy-friendly, no cookies)
# ------------------------------------------------------------------------------
# Internal URL of your Umami instance reachable from the app container.
# In production (Docker): http://host.docker.internal:3001
# In local dev: http://localhost:3001  (if Umami is running locally)
# Leave empty to disable analytics entirely.
UMAMI_INTERNAL_URL=""
# The website ID shown in Umami → Settings → Websites
UMAMI_WEBSITE_ID=""
