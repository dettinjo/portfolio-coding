# See https://help.github.com/articles/ignoring-files/ for more about ignoring files.

# dependencies
/node_modules
/.pnp
.pnp.*
.yarn/*
!.yarn/patches
!.yarn/plugins
!.yarn/releases
!.yarn/versions

# testing
/coverage

# next.js
/.next/
/out/

# production
/build

# misc
.DS_Store
*.pem

# local editor / agent state
.claude/

# debug
npm-debug.log*
yarn-debug.log*
yarn-error.log*
.pnpm-debug.log*

# Environment Variables
# Ignore all local environment files that contain sensitive secrets.
.env*

# But DO NOT ignore the example template file. The '!' negates the rule.
# This file should always be committed to the repository.
!.env.example

# vercel
.vercel

# typescript
*.tsbuildinfo
next-env.d.ts
.repomix-output.xml

# database
*.db
*.sqlite
*.sqlite3
*.sql

# logs
*.log

# generated project media (built by fetch-portfolio.ts)
/public/media/projects/

# local personal config (real values live in the portfolio-config repo;
# this is an optional local/offline override and must never be committed)
/config/site.config.json

# generated build-time files
/src/data/projects.json
/src/data/skills.json
/src/data/resume.json
/src/data/site.config.json
/public/images/profile.webp
/public/og-software.png
/public/media/resume.pdf